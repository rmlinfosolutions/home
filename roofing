<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Free Roof Inspection | Fast Roofing Services</title>

<!-- Google Font -->

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<!-- Icons -->

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<style>
body {
    font-family: 'Poppins', sans-serif;
    margin: 0;
    background: #f5f7fa;
}

/* URGENCY BAR */
.urgency {
    background: #ff3b3b;
    color: white;
    text-align: center;
    padding: 10px;
    font-weight: 600;
}

/* HERO */
.hero {
    background: linear-gradient(135deg, #1e3a5f, #0f172a);
    color: white;
    text-align: center;
    padding: 60px 20px;
}

.hero h1 {
    font-size: 32px;
}

.hero p {
    font-size: 18px;
}

/* CTA BUTTON */
.cta-btn {
    background: #ff6600;
    color: white;
    padding: 14px 25px;
    border-radius: 6px;
    text-decoration: none;
    display: inline-block;
    margin-top: 20px;
    font-weight: bold;
}

/* TRUST */
.trust {
    display: flex;
    justify-content: space-around;
    flex-wrap: wrap;
    padding: 20px;
    text-align: center;
}

.trust div {
    margin: 10px;
}

/* FORM */
.form-box {
    background: white;
    max-width: 420px;
    margin: 30px auto;
    padding: 25px;
    border-radius: 10px;
    box-shadow: 0 0 15px rgba(0,0,0,0.1);
}

input, select {
    width: 100%;
    padding: 12px;
    margin: 10px 0;
    border-radius: 6px;
    border: 1px solid #ccc;
}

button {
    width: 100%;
    background: #ff6600;
    color: white;
    padding: 14px;
    border: none;
    border-radius: 6px;
    font-size: 16px;
}

/* MULTI STEP */
.step { display: none; }
.step.active { display: block; }

/* FLOAT BUTTONS */
.call-btn, .whatsapp-btn {
    position: fixed;
    bottom: 20px;
    padding: 16px;
    border-radius: 50%;
    color: white;
    font-size: 20px;
    z-index: 999;
}

.call-btn {
    right: 20px;
    background: #28a745;
}

.whatsapp-btn {
    right: 80px;
    background: #25D366;
}

/* FOOTER */
.footer {
    text-align: center;
    padding: 20px;
    font-size: 13px;
    color: #555;
}
</style>

</head>

<body>

<div class="urgency">
⚠️ Limited Same-Day Appointments Available – Book Now
</div>

<div class="hero">
<h1>Get a Free Roof Inspection Near You</h1>
<p>Fast, Reliable Roofing Services for Repairs, Leaks & Storm Damage</p>
<a href="#form" class="cta-btn">Check Availability</a>
</div>

<div class="trust">
<div><i class="fa fa-check"></i><br>Licensed & Insured</div>
<div><i class="fa fa-clock"></i><br>Same-Day Service</div>
<div><i class="fa fa-star"></i><br>Top Rated Contractors</div>
</div>

<div id="form" class="form-box">

<form id="multiStepForm">

<!-- STEP 1 -->

<div class="step active">
<h3>Step 1: Enter ZIP Code</h3>
<input type="text" name="zip" placeholder="ZIP Code" required>
<button type="button" onclick="nextStep()">Next</button>
</div>

<!-- STEP 2 -->

<div class="step">
<h3>Step 2: Service Needed</h3>
<select name="service" required>
<option value="">Select Service</option>
<option>Roof Repair</option>
<option>Roof Replacement</option>
<option>Leak Inspection</option>
<option>Storm Damage</option>
</select>
<button type="button" onclick="nextStep()">Next</button>
</div>

<!-- STEP 3 -->

<div class="step">
<h3>Step 3: Your Details</h3>
<input type="text" name="name" placeholder="Full Name" required>
<input type="tel" name="phone" placeholder="Phone Number" required>
<button type="submit">Get Free Estimate</button>
</div>

</form>

</div>

<!-- FLOATING BUTTONS -->

<a href="tel:+1234567890" class="call-btn">
<i class="fa fa-phone"></i>
</a>

<a href="https://wa.me/1234567890" class="whatsapp-btn" target="_blank">
<i class="fab fa-whatsapp"></i>
</a>

<div class="footer">
<p>This website is a lead generation service. We connect homeowners with local roofing professionals. By submitting your information, you agree to be contacted by our partners.</p>
</div>

<script>
let currentStep = 0;
const steps = document.querySelectorAll(".step");

function nextStep() {
    const inputs = steps[currentStep].querySelectorAll("input, select");
    for (let input of inputs) {
        if (!input.checkValidity()) {
            input.reportValidity();
            return;
        }
    }
    steps[currentStep].classList.remove("active");
    currentStep++;
    steps[currentStep].classList.add("active");
}

document.getElementById("multiStepForm").addEventListener("submit", function(e) {
    e.preventDefault();
    alert("Thank you! We will contact you shortly.");
});
</script>

</body>
</html>
